NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# Use a chave que o painel do Supabase indicar (nome novo):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sua-chave-publica
# Alternativa aceita pela app (mesmo valor que "anon public" em projetos antigos):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Autenticação (JWT em cookie): defina uma string aleatória com pelo menos 16 caracteres.
AUTH_SECRET=
# Service role — só no servidor (rotas /api/auth e /api/integrantes POST). Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=
